{
  "name": "AlMadar",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "npm run build:data-quality && strapi build",
    "build:data-quality": "npm --prefix src/plugins/data-quality run build",
    "ci": "npm test && npm run build",
    "deploy": "strapi deploy",
    "develop": "strapi develop",
    "github:issues": "node scripts/import-github-issues.js",
    "github:issues:apply": "node scripts/import-github-issues.js --apply",
    "migration:dry-run": "npm --prefix etl run audit:fields && npm --prefix etl run transform && npm --prefix etl run load",
    "migration:apply": "npm --prefix etl run load:apply",
    "permissions": "node scripts/configure-permissions.js",
    "permissions:apply": "node scripts/configure-permissions.js --apply",
    "start": "strapi start",
    "strapi": "strapi",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@_sh/strapi-plugin-ckeditor": "^7.1.1",
    "@sindresorhus/slugify": "1.1.0",
    "@strapi/design-system": "2.2.0",
    "@strapi/icons": "2.2.0",
    "@strapi/plugin-cloud": "^5.49.0",
    "@strapi/plugin-documentation": "^5.49.0",
    "@strapi/plugin-users-permissions": "^5.49.0",
    "@strapi/strapi": "^5.49.0",
    "better-sqlite3": "^12.11.1",
    "fs-extra": "^11.3.5",
    "mime-types": "^3.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "strapi-location-picker": "^0.0.3",
    "styled-components": "6.4.2"
  },
  "engines": {
    "node": ">=20.0.0 <=22.x.x",
    "npm": ">=6.0.0"
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "5.4.0"
  }
}
