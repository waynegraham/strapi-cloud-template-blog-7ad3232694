{
  "kind": "collectionType",
  "collectionName": "galleries",
  "info": {
    "singularName": "gallery",
    "pluralName": "galleries",
    "displayName": "Gallery"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "eyebrowEn": {
      "type": "string"
    },
    "eyebrowAr": {
      "type": "string"
    },
    "nameEn": {
      "type": "string"
    },
    "nameAr": {
      "type": "string"
    },
    "displayTitle": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "nameEn"
    },
    "sortOrder": {
      "type": "integer",
      "min": 0
    },
    "level": {
      "type": "enumeration",
      "enum": [
        "gallery",
        "section"
      ],
      "default": "gallery"
    },
    "coverMedia": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "descriptionEn": {
      "type": "blocks"
    },
    "descriptionAr": {
      "type": "blocks"
    },
    "biennale_edition": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::biennale-edition.biennale-edition",
      "inversedBy": "galleries"
    },
    "parent": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::gallery.gallery",
      "inversedBy": "children"
    },
    "children": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::gallery.gallery",
      "mappedBy": "parent"
    },
    "works": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::work.work",
      "mappedBy": "gallery"
    }
  }
}
