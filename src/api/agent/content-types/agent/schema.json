{
  "kind": "collectionType",
  "collectionName": "agents",
  "info": {
    "singularName": "agent",
    "pluralName": "agents",
    "displayName": "Agent"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nameEn": {
      "type": "string"
    },
    "nameAr": {
      "type": "string"
    },
    "externalIdentifier": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "nameEn"
    },
    "biographyEn": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "biographyAr": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "url": {
      "type": "string"
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "agent_roles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::agent-role.agent-role",
      "inversedBy": "agents"
    }
  }
}
