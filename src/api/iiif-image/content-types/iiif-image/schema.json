{
  "kind": "collectionType",
  "collectionName": "iiif_images",
  "info": {
    "singularName": "iiif-image",
    "pluralName": "iiif-images",
    "displayName": "IIIF Image"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "sequence": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "label": {
      "type": "string"
    },
    "folioLabel": {
      "type": "string"
    },
    "s3key": {
      "type": "string"
    },
    "cantaloupeIdentifier": {
      "type": "string",
      "required": true
    },
    "width": {
      "type": "integer"
    },
    "height": {
      "type": "integer"
    },
    "infoJsonUrl": {
      "type": "string"
    },
    "thumbnailUrl": {
      "type": "string"
    },
    "captionEn": {
      "type": "string"
    },
    "captionAr": {
      "type": "string"
    },
    "rights": {
      "type": "string"
    },
    "iiifAsset": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::iiif-asset.iiif-asset",
      "inversedBy": "images",
      "required": true
    }
  }
}
