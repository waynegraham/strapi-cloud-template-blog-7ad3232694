{
  "kind": "collectionType",
  "collectionName": "iiif_assets",
  "info": {
    "singularName": "iiif-asset",
    "pluralName": "iiif-assets",
    "displayName": "IIIF Asset"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "processingState": {
      "type": "enumeration",
      "default": "draft",
      "enum": [
        "draft",
        "uploaded",
        "processing",
        "ready",
        "failed"
      ]
    },
    "manifestUrl": {
      "type": "string"
    },
    "work": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::work.work",
      "inversedBy": "iiif_assets"
    },
    "title": {
      "type": "string"
    },
    "iiifBaseUrl": {
      "type": "string"
    },
    "processingErrors": {
      "type": "text"
    }
  }
}
