{
  "kind": "collectionType",
  "collectionName": "works",
  "info": {
    "singularName": "work",
    "pluralName": "works",
    "displayName": "Work"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "iabCode": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "titleEn": {
      "type": "string",
      "required": true
    },
    "titleAr": {
      "type": "string"
    },
    "originEn": {
      "type": "string"
    },
    "originAr": {
      "type": "string"
    },
    "dateDisplayGregorianEn": {
      "type": "string"
    },
    "dateDisplayGregorianAr": {
      "type": "string"
    },
    "dateDisplayHijriEn": {
      "type": "string"
    },
    "dateDisplayHijriAr": {
      "type": "string"
    },
    "earliestDate": {
      "type": "integer"
    },
    "latestDate": {
      "type": "integer"
    },
    "creditLineEn": {
      "type": "string"
    },
    "creditLineAr": {
      "type": "string"
    },
    "contributorUrl": {
      "type": "string"
    },
    "gallery": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::gallery.gallery"
    },
    "institution": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::institution.institution"
    },
    "agentCredits": {
      "type": "component",
      "component": "shared.agent-credit",
      "repeatable": true
    },
    "descriptionEn": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "descriptionAr": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "footnoteEn": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "footnoteAr": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "iiif_assets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::iiif-asset.iiif-asset",
      "mappedBy": "work"
    }
  }
}
