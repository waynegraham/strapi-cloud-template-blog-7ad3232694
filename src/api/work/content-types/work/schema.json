{
  "kind": "collectionType",
  "collectionName": "works",
  "info": {
    "singularName": "work",
    "pluralName": "works",
    "displayName": "Work"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "iabCode": {
      "type": "string",
      "required": true
    },
    "identifiers": {
      "type": "component",
      "component": "shared.work-identifier",
      "repeatable": true,
      "required": true
    },
    "inscriptions": {
      "type": "component",
      "component": "shared.inscription",
      "repeatable": true
    },
    "titleEn": {
      "type": "string",
      "required": true
    },
    "titleAr": {
      "type": "string"
    },
    "originEn": {
      "type": "string"
    },
    "originAr": {
      "type": "string"
    },
    "dimensionEn": {
      "type": "text"
    },
    "dimensionAr": {
      "type": "text"
    },
    "materialDisplayEn": {
      "type": "text"
    },
    "materialDisplayAr": {
      "type": "text"
    },
    "dateDisplayGregorianEn": {
      "type": "string"
    },
    "dateDisplayGregorianAr": {
      "type": "string"
    },
    "dateDisplayHijriEn": {
      "type": "string"
    },
    "dateDisplayHijriAr": {
      "type": "string"
    },
    "earliestDate": {
      "type": "integer"
    },
    "latestDate": {
      "type": "integer"
    },
    "creditLineEn": {
      "type": "string"
    },
    "creditLineAr": {
      "type": "string"
    },
    "contributorUrl": {
      "type": "string"
    },
    "gallery": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::gallery.gallery",
      "inversedBy": "works"
    },
    "institution": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::institution.institution",
      "inversedBy": "works"
    },
    "materials": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::material.material"
    },
    "agentCredits": {
      "type": "component",
      "component": "shared.agent-credit",
      "repeatable": true
    },
    "descriptionEn": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "descriptionAr": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "additionalDescriptions": {
      "type": "component",
      "component": "shared.work-description",
      "repeatable": true
    },
    "footnoteEn": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "footnoteAr": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "iiif_assets": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::iiif-asset.iiif-asset",
      "mappedBy": "work"
    },
    "curatedStories": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::curated-story.curated-story",
      "mappedBy": "works"
    }
  }
}
