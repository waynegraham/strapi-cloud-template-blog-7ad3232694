{
  "kind": "collectionType",
  "collectionName": "institutions",
  "info": {
    "singularName": "institution",
    "pluralName": "institutions",
    "displayName": "Institution"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nameEn": {
      "type": "string"
    },
    "nameAr": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "nameEn"
    },
    "descriptionEn": {
      "type": "blocks"
    },
    "descriptionAr": {
      "type": "blocks"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "url": {
      "type": "string"
    },
    "location": {
      "type": "customField",
      "customField": "plugin::strapi-location-picker.location-picker",
      "options": {
        "info": true
      }
    },
    "works": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::work.work",
      "mappedBy": "institution"
    }
  }
}
